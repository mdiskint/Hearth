{
    "manifest_version": 3,
    "name": "Hearth - AI That Knows You",
    "version": "0.1.0",
    "description": "Personalized AI across every platform. Your preferences and memories, everywhere.",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://olqyvnqaosfkzhttjqzt.supabase.co/*",
        "https://api.anthropic.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://claude.ai/*",
                "https://chat.openai.com/*",
                "https://chatgpt.com/*",
                "https://gemini.google.com/*"
            ],
            "js": [
                "content/injector.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_page": "options/options.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}